# IBM Cloud Credentials
# Copy this file to .env and fill in your actual values

# IBM Watson Machine Learning API Key
# Obtain from IBM Cloud > Manage > Access (IAM) > API keys
IBM_API_KEY=your_ibm_cloud_api_key_here

# IBM Cloud Region / URL
# Common values: https://us-south.ml.cloud.ibm.com
#                https://eu-gb.ml.cloud.ibm.com
#                https://eu-de.ml.cloud.ibm.com
#                https://jp-tok.ml.cloud.ibm.com
IBM_WML_URL=https://us-south.ml.cloud.ibm.com

# Watson Machine Learning Deployment Space ID
# Obtain from IBM Watson Studio > Deployments > Your Space > Manage > Space GUID
IBM_SPACE_ID=your_deployment_space_id_here

# AutoAI Deployment ID
# Obtain after deploying your AutoAI model in Watson Studio Deployments
IBM_DEPLOYMENT_ID=your_autoai_deployment_id_here

# Flask Configuration
FLASK_SECRET_KEY=change_this_to_a_random_secret_key_in_production
FLASK_DEBUG=False
FLASK_PORT=5000

# App Configuration
MAX_PREDICTION_HISTORY=50
